		{
			"name": "4. Observations",
			"item": [
				{
					"name": "Search Observations for Patient",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/fhir+json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/Observation?patient={{patientId}}",
							"host": ["{{baseUrl}}"],
							"path": ["Observation"],
							"query": [
								{
									"key": "patient",
									"value": "{{patientId}}"
								}
							]
						},
						"description": "Search all observations linked to a patient."
					},
					"response": []
				},
				{
					"name": "Create Observation",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Status is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Observation created with ID\", function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.id).to.be.a(\"string\");",
									"    pm.collectionVariables.set(\"observationId\", json.id);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/fhir+json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"resourceType\": \"Observation\",\n  \"status\": \"final\",\n  \"code\": {\"coding\": [{\"system\": \"http://loinc.org\", \"code\": \"29463-7\", \"display\": \"Body Weight\"}]},\n  \"subject\": {\"reference\": \"Patient/{{patientId}}\"},\n  \"effectiveDateTime\": \"2026-03-04T10:00:00Z\",\n  \"valueQuantity\": {\"value\": 85, \"unit\": \"kg\", \"system\": \"http://unitsofmeasure.org\", \"code\": \"kg\"},\n  \"category\": [{\"coding\": [{\"system\": \"http://terminology.hl7.org/CodeSystem/observation-category\", \"code\": \"vital-signs\", \"display\": \"Vital Signs\"}]}]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/Observation",
							"host": ["{{baseUrl}}"],
							"path": ["Observation"]
						},
						"description": "Create a new observation. This triggers the goal evaluation engine. The returned ID is saved to the `observationId` collection variable."
					},
					"response": []
				},
				{
					"name": "Create Observation (Goal Achievement Trigger)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Status is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Observation created with ID\", function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.id).to.be.a(\"string\");",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/fhir+json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"resourceType\": \"Observation\",\n  \"status\": \"final\",\n  \"code\": {\"coding\": [{\"system\": \"http://loinc.org\", \"code\": \"29463-7\", \"display\": \"Body Weight\"}]},\n  \"subject\": {\"reference\": \"Patient/{{patientId}}\"},\n  \"effectiveDateTime\": \"2026-03-04T14:00:00Z\",\n  \"valueQuantity\": {\"value\": 79, \"unit\": \"kg\", \"system\": \"http://unitsofmeasure.org\", \"code\": \"kg\"},\n  \"category\": [{\"coding\": [{\"system\": \"http://terminology.hl7.org/CodeSystem/observation-category\", \"code\": \"vital-signs\", \"display\": \"Vital Signs\"}]}]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/Observation",
							"host": ["{{baseUrl}}"],
							"path": ["Observation"]
						},
						"description": "This observation's weight (79kg) is below the goal target (80kg), which should trigger automatic goal achievement. After running this request, check the goal's lifecycleStatus — it should be updated to 'achieved'."
					},
					"response": []
				},
