{
	"info": {
		"_postman_id": "fhir-goals-engine-collection",
		"name": "FHIR Goals Engine",
		"description": "Postman collection for the FHIR R4 Health Goals Engine API. Covers Patient, Goal, CarePlan, Observation CRUD, and AI-powered goal suggestions.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		},
		{
			"key": "patientId",
			"value": ""
		},
		{
			"key": "goalId",
			"value": ""
		},
		{
			"key": "carePlanId",
			"value": ""
		},
		{
			"key": "observationId",
			"value": ""
		}
	],
	"item": [
		{
			"name": "1. Patients",
			"item": [
				{
					"name": "Search All Patients",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Status is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response is a Bundle\", function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.resourceType).to.eql(\"Bundle\");",
									"});",
									"",
									"if (pm.response.json().entry && pm.response.json().entry.length > 0) {",
									"    pm.collectionVariables.set(\"patientId\", pm.response.json().entry[0].resource.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/fhir+json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/Patient",
							"host": ["{{baseUrl}}"],
							"path": ["Patient"]
						},
						"description": "Search all patients. If results exist, the first patient's ID is saved to the `patientId` collection variable."
					},
					"response": []
				},
				{
					"name": "Create Patient",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Status is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Patient created with ID\", function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.id).to.be.a(\"string\");",
									"    pm.collectionVariables.set(\"patientId\", json.id);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/fhir+json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"resourceType\": \"Patient\",\n  \"active\": true,\n  \"name\": [{\"family\": \"Demo\", \"given\": [\"Postman\"]}],\n  \"gender\": \"male\",\n  \"birthDate\": \"1990-01-15\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/Patient",
							"host": ["{{baseUrl}}"],
							"path": ["Patient"]
						},
						"description": "Create a new patient. The returned ID is saved to the `patientId` collection variable."
					},
					"response": []
				},
				{
					"name": "Get Patient by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/fhir+json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/Patient/{{patientId}}",
							"host": ["{{baseUrl}}"],
							"path": ["Patient", "{{patientId}}"]
						},
						"description": "Retrieve a single patient by ID."
					},
					"response": []
				},
				{
					"name": "Update Patient",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/fhir+json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"resourceType\": \"Patient\",\n  \"active\": true,\n  \"name\": [{\"family\": \"Demo\", \"given\": [\"Postman\"]}],\n  \"gender\": \"female\",\n  \"birthDate\": \"1990-01-15\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/Patient/{{patientId}}",
							"host": ["{{baseUrl}}"],
							"path": ["Patient", "{{patientId}}"]
						},
						"description": "Update an existing patient. This example changes gender from male to female."
					},
					"response": []
				},
				{
					"name": "Delete Patient",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/Patient/{{patientId}}",
							"host": ["{{baseUrl}}"],
							"path": ["Patient", "{{patientId}}"]
						},
						"description": "Delete a patient by ID. Returns 204 No Content on success."
					},
					"response": []
				}
			],
			"description": "CRUD operations for FHIR Patient resources."
		},
		{
			"name": "2. Goals",
			"item": [
				{
					"name": "Search Goals for Patient",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/fhir+json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/Goal?patient={{patientId}}",
							"host": ["{{baseUrl}}"],
							"path": ["Goal"],
							"query": [
								{
									"key": "patient",
									"value": "{{patientId}}"
								}
							]
						},
						"description": "Search all goals linked to a patient."
					},
					"response": []
				},
				{
					"name": "Create Goal",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Status is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Goal created with ID\", function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.id).to.be.a(\"string\");",
									"    pm.collectionVariables.set(\"goalId\", json.id);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/fhir+json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"resourceType\": \"Goal\",\n  \"lifecycleStatus\": \"active\",\n  \"description\": {\"text\": \"Reduce body weight to 80kg\"},\n  \"subject\": {\"reference\": \"Patient/{{patientId}}\"},\n  \"category\": [{\"coding\": [{\"system\": \"http://terminology.hl7.org/CodeSystem/goal-category\", \"code\": \"dietary\", \"display\": \"Dietary\"}]}],\n  \"target\": [{\n    \"measure\": {\"coding\": [{\"system\": \"http://loinc.org\", \"code\": \"29463-7\", \"display\": \"Body Weight\"}]},\n    \"detailQuantity\": {\"value\": 80, \"unit\": \"kg\", \"system\": \"http://unitsofmeasure.org\"},\n    \"dueDate\": \"2026-06-01\"\n  }],\n  \"startDate\": \"2026-03-04\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/Goal",
							"host": ["{{baseUrl}}"],
							"path": ["Goal"]
						},
						"description": "Create a new health goal for the patient. The returned ID is saved to the `goalId` collection variable."
					},
					"response": []
				},
				{
					"name": "Get Goal by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/fhir+json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/Goal/{{goalId}}",
							"host": ["{{baseUrl}}"],
							"path": ["Goal", "{{goalId}}"]
						},
						"description": "Retrieve a single goal by ID."
					},
					"response": []
				},
				{
					"name": "Update Goal",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/fhir+json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"resourceType\": \"Goal\",\n  \"lifecycleStatus\": \"on-hold\",\n  \"description\": {\"text\": \"Reduce body weight to 80kg\"},\n  \"subject\": {\"reference\": \"Patient/{{patientId}}\"},\n  \"category\": [{\"coding\": [{\"system\": \"http://terminology.hl7.org/CodeSystem/goal-category\", \"code\": \"dietary\", \"display\": \"Dietary\"}]}],\n  \"target\": [{\n    \"measure\": {\"coding\": [{\"system\": \"http://loinc.org\", \"code\": \"29463-7\", \"display\": \"Body Weight\"}]},\n    \"detailQuantity\": {\"value\": 80, \"unit\": \"kg\", \"system\": \"http://unitsofmeasure.org\"},\n    \"dueDate\": \"2026-06-01\"\n  }],\n  \"startDate\": \"2026-03-04\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/Goal/{{goalId}}",
							"host": ["{{baseUrl}}"],
							"path": ["Goal", "{{goalId}}"]
						},
						"description": "Update an existing goal. This example changes lifecycleStatus from active to on-hold."
					},
					"response": []
				},
				{
					"name": "Delete Goal",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/Goal/{{goalId}}",
							"host": ["{{baseUrl}}"],
							"path": ["Goal", "{{goalId}}"]
						},
						"description": "Delete a goal by ID. Returns 204 No Content on success."
					},
					"response": []
				}
			],
			"description": "CRUD operations for FHIR Goal resources."
		},
		{
